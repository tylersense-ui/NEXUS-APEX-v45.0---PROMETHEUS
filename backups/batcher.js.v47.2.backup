 *   /lib/logger.js       - SystГЁme de logs
 *   /core/network.js     - Scanner rГ©seau
 *   /core/ram-manager.js - Gestion RAM
 *   /core/port-handler.js - Communication ports
 *   /lib/capabilities.js - DГ©tection APIs
 * 
 * @exports
 *   class Batcher        - Classe principale du batcher
 */

import { CONFIG } from "/lib/constants.js";
import { Logger } from "/lib/logger.js";

/**
 * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
 * рҹ“ҳ CLASSE BATCHER - LE CЕ’UR DE PROMETHEUS (v47.0 ABSOLUTE ZERO BUGS)
 * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
 * Calcule, optimise et dispatch les batchs HWGW avec algorithmes avancГ©s.
 * VERSION v47.0 avec TOUTES les corrections et validations.
 * 
 * @class
 */
export class Batcher {
    /**
     * Constructeur du Batcher
     * 
     * @param {NS} ns - Namespace BitBurner
     * @param {Network} network - Instance du Network scanner
     * @param {RamManager} ramMgr - Instance du RAM Manager
     * @param {PortHandler} portHandler - Instance du Port Handler
     * @param {Capabilities} caps - Instance des Capabilities
     */
    constructor(ns, network, ramMgr, portHandler, caps) {
        this.ns = ns;
        this.network = network;
        this.ramMgr = ramMgr;
        this.portHandler = portHandler;
        this.caps = caps;
        this.log = new Logger(ns, "BATCHER");
        
        /**
         * MГ©triques du batcher
         * @private
         */
        this._metrics = {
            batchesCreated: 0,
            batchesDispatched: 0,
            totalThreadsPlanned: 0,
            totalThreadsDispatched: 0,
            totalRamWaste: 0,
            lastBatchTime: 0,
            optimalHackPercents: {},
            jobsSplit: 0,
            totalSubjobs: 0,
            prepBatchesCreated: 0,
            progressiveSteps: 0,
            criticalErrors: 0
        };
        
        /** @type {boolean} Mode debug */
        this._debugMode = CONFIG.SYSTEM.DEBUG_MODE || false;
        
        /** @type {Object} Dernier recalcul EV/s par target */
        this._lastEVRecalc = {};
        
        /**
         * Cache RAM des workers avec TTL
         * @private
         */
        this._workerRamCache = null;
        this._workerRamCacheTime = 0;
    }

    /**
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * рҹҺҜ MГүTHODE PRINCIPALE : EXECUTE BATCH
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * Calcule et exГ©cute un batch HWGW complet sur une cible.
     * 
     * @public
     * @param {string} target - Hostname de la cible
     * @returns {Promise<Object>} RГ©sultats du batch { success, jobs, threadsUsed, isPrep }
     */
    async executeBatch(target) {
        try {
            // 1. VГ©rifier si le serveur nГ©cessite prГ©paration
            const server = this.ns.getServer(target);
            const prepStatus = this._checkPrepStatus(server);

            if (!prepStatus.ready) {
                // CrГ©er batch de prГ©paration PROGRESSIVE
                const prepJobs = this._createProgressivePrepBatch(target, prepStatus);
                
                if (!prepJobs || prepJobs.length === 0) {
                    return { success: false, jobs: [], threadsUsed: 0 };
                }
                
                const packedJobs = this._packJobs(prepJobs);
                const dispatched = await this._dispatchJobs(packedJobs);
                
                this._metrics.batchesCreated++;
                this._metrics.prepBatchesCreated++;
                this._metrics.progressiveSteps++;
                
                return { success: dispatched > 0, isPrep: true, jobs: packedJobs, threadsUsed: dispatched };
            }

            // 2. Serveur prГӘt вҶ’ Batch HWGW normal
            const hackPercent = this._calculateOptimalHackPercent(target);
            
            if (this._debugMode) {
                this.log.debug(`рҹ”Ҙ hackPercent optimal pour ${target}: ${(hackPercent * 100).toFixed(1)}%`);
            }
            
            const jobs = this._calculateBatchJobs(target, hackPercent);
            
            if (!jobs || jobs.length === 0) {
                return { success: false, jobs: [], threadsUsed: 0 };
            }
            
            // 3. Filtrer les jobs avec 0 threads (edge case: serveur optimal)
            const validJobs = jobs.filter(j => {
                if (j.threads === 0) {
                    this.log.warn(`Job ${j.type} skippГ© (0 threads, serveur optimal)`);
                    return false;
                }
                return true;
            });
            
            if (validJobs.length === 0) {
                this.log.warn(`Aucun job valide pour ${target} (tous Г  0 threads)`);
                return { success: false, jobs: [], threadsUsed: 0 };
            }
            
            // 4. Pack et dispatch
            const packedJobs = this._packJobs(validJobs);
            const dispatched = await this._dispatchJobs(packedJobs);
            
            this._metrics.batchesCreated++;
            this._metrics.totalThreadsPlanned += validJobs.reduce((sum, j) => sum + j.threads, 0);
            this._metrics.totalThreadsDispatched += dispatched;
            
            return { success: dispatched > 0, isPrep: false, jobs: packedJobs, threadsUsed: dispatched };
            
        } catch (error) {
            this.log.error(`Erreur executeBatch(${target}): ${error.message}`);
            this._metrics.criticalErrors++;
            return { success: false, jobs: [], threadsUsed: 0 };
        }
    }

    /**
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * рҹ”¬ CHECK PREP STATUS
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * VГ©rifie si un serveur est prГӘt pour HWGW ou nГ©cessite prГ©paration.
     * 
     * @private
     * @param {Server} server - Objet serveur (ns.getServer)
     * @returns {Object} { ready, needsWeaken, needsGrow, securityDelta, moneyPercent }
     */
    _checkPrepStatus(server) {
        const minSecurity = server.minDifficulty;
        const currentSecurity = server.hackDifficulty;
        const maxMoney = server.moneyMax;
        const currentMoney = server.moneyAvailable;
        
        // Buffer de sГ©curitГ© configurable
        const SECURITY_BUFFER = CONFIG.HACKING?.SECURITY_BUFFER || 2;
        
        // Seuils de prГ©paration
        const needsWeaken = (currentSecurity > minSecurity + SECURITY_BUFFER);
        const needsGrow = (currentMoney < maxMoney * 0.75);  // 75% minimum
        
        return {
            ready: !needsWeaken && !needsGrow,
            needsWeaken: needsWeaken,
            needsGrow: needsGrow,
            securityDelta: Math.max(0, currentSecurity - (minSecurity + SECURITY_BUFFER)),
            moneyPercent: maxMoney > 0 ? currentMoney / maxMoney : 0
        };
    }

    /**
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * рҹҶ• v47.0 : PRГүPARATION PROGRESSIVE (TOUS BUGS CORRIGГүS)
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * CrГ©e un batch de prГ©paration avec croissance progressive pour Г©viter
     * le dГ©sГ©quilibre massif grow/weaken.
     * 
     * STRATГүGIE :
     * - Au lieu de viser 75% en un coup (grow threads massifs)
     * - On multiplie par MAX 3x par batch
     * - Exemple : 4% вҶ’ 12% вҶ’ 36% вҶ’ 75% (3 cycles)
     * - Ratio grow/weaken Г©quilibrГ© (~3-4:1)
     * 
     * @private
     * @param {string} target - Hostname de la cible
     * @param {Object} prepStatus - Statut prep (depuis _checkPrepStatus)
     * @returns {Array<Object>} Liste de jobs de prГ©paration
     */
    _createProgressivePrepBatch(target, prepStatus) {
        const server = this.ns.getServer(target);
        const { weakenRam, growRam } = this._getWorkerRamCosts();
        const jobs = [];
        
        // DurГ©es d'exГ©cution
        const weakenTime = this.ns.getWeakenTime(target);
        const growTime = this.ns.getGrowTime(target);
        const SPACING = 500; // v46.0 OPTIMISГү : 200ms вҶ’ 500ms (sГ©curitГ© collision)
        
        // в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
        // PARAMГҲTRES DE PRГүPARATION PROGRESSIVE (GODMODE v46.0)
        // в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
        const MAX_GROWTH_MULT = 3.0;  // OPTIMISГү : 5x вҶ’ 3x (stabilitГ©)
        const MAX_THREADS_PER_JOB = CONFIG.HACKING?.MAX_GROW_THREADS || 2000;
        const MONEY_TARGET = 0.75;  // Objectif final 75%
        
        // в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
        // CAS 1 : WEAKEN UNIQUEMENT
        // в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
        if (prepStatus.needsWeaken && !prepStatus.needsGrow) {
            const securityToReduce = prepStatus.securityDelta;
            let weakenThreads = Math.ceil(securityToReduce / 0.05);
            weakenThreads = Math.min(weakenThreads, MAX_THREADS_PER_JOB);
            
            if (weakenThreads > 0) {
                jobs.push({
                    type: "weaken",
                    target: target,
                    threads: weakenThreads,
                    ramPerThread: weakenRam,
                    delay: 0,
                    priority: 1,
                    endTime: Date.now() + weakenTime
                });
                
                this.log.info(`рҹӣЎпёҸ  Prep WEAKEN only: ${weakenThreads}t (sec: ${prepStatus.securityDelta.toFixed(1)} вҶ’ +${CONFIG.HACKING?.SECURITY_BUFFER || 2})`);
            }
            
            return jobs;
        }
        
        // в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
        // CAS 2 : GROW + WEAKEN COMPENSATOIRE (v47.0 BUG #11 CORRIGГү)
        // в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
        if (!prepStatus.needsWeaken && prepStatus.needsGrow) {
            // Calcul grow
            const currentPercent = prepStatus.moneyPercent;
            const targetPercent = Math.min(currentPercent * MAX_GROWTH_MULT, MONEY_TARGET);
            const growthNeeded = targetPercent / currentPercent;
            
            let growThreads = this.ns.growthAnalyze(target, growthNeeded);
            growThreads = Math.ceil(growThreads);
            growThreads = Math.min(growThreads, MAX_THREADS_PER_JOB);
            
            // вң… v47.0 BUG #11 CORRIGГү : WEAKEN compensatoire OBLIGATOIRE
            // GROW augmente TOUJOURS la security (+0.004 par thread)
            const growSecurityIncrease = growThreads * 0.004;
            const compensateWeakenThreads = Math.ceil(growSecurityIncrease / 0.05);
            
            // Timeline: GROW finit Г  T, WEAKEN finit Г  T + SPACING
            const now = Date.now();
            const growDelay = Math.max(0, weakenTime - growTime);
            const weaken2Delay = SPACING;
            
            // JOB 1: GROW
            if (growThreads > 0) {
                jobs.push({
                    type: "grow",
                    target: target,
                    threads: growThreads,
                    ramPerThread: growRam,
                    delay: growDelay,
                    priority: 1,
                    endTime: now + growDelay + growTime
                });
            }
            
            // JOB 2: WEAKEN compensatoire
            if (compensateWeakenThreads > 0) {
                jobs.push({
                    type: "weaken",
                    target: target,
                    threads: compensateWeakenThreads,
                    ramPerThread: weakenRam,
                    delay: weaken2Delay,
                    priority: 2,
                    endTime: now + weaken2Delay + weakenTime
                });
            }
            
            this.log.info(
                `рҹҢұ Prep GROW: G${growThreads}t + W${compensateWeakenThreads}t ` +
                `(${(currentPercent * 100).toFixed(0)}% вҶ’ ${(targetPercent * 100).toFixed(0)}%)`
            );
            
            return jobs;
        }
        
        // в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
        // CAS 3 : WEAKEN + GROW + WEAKEN (v46.2 + v47.0 VALIDГү)
        // в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
        if (prepStatus.needsWeaken && prepStatus.needsGrow) {
            // WEAKEN initial
            const securityToReduce = prepStatus.securityDelta;
            let weakenThreads = Math.ceil(securityToReduce / 0.05);
            weakenThreads = Math.min(weakenThreads, MAX_THREADS_PER_JOB);
            
            // GROW avec croissance PROGRESSIVE
            const currentPercent = prepStatus.moneyPercent;
            const targetPercent = Math.min(currentPercent * MAX_GROWTH_MULT, MONEY_TARGET);
            const growthNeeded = targetPercent / currentPercent;
            
            let growThreads = this.ns.growthAnalyze(target, growthNeeded);
            growThreads = Math.ceil(growThreads);
            growThreads = Math.min(growThreads, MAX_THREADS_PER_JOB);
            
            // WEAKEN compensatoire pour GROW
            const growSecurityIncrease = growThreads * 0.004;
            const compensateWeakenThreads = Math.ceil(growSecurityIncrease / 0.05);
            
            // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
            // вң… v46.2 + v47.0 VALIDГү : TIMELINE SYNCHRONISГүE
            // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
            // WEAKEN1 termine Г  T (le plus long, delay=0)
            // GROW termine Г  T + SPACING (aprГЁs que weaken ait baissГ© la sec)
            // WEAKEN2 termine Г  T + 2Г—SPACING (compense la sec ajoutГ©e par grow)
            // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
            
            const now = Date.now();
            
            // JOB 1: WEAKEN initial
            if (weakenThreads > 0) {
                jobs.push({
                    type: "weaken",
                    target: target,
                    threads: weakenThreads,
                    ramPerThread: weakenRam,
                    delay: 0,
                    priority: 1,
                    endTime: now + weakenTime
                });
            }
            
            // JOB 2: GROW (termine SPACING ms APRГҲS WEAKEN1) - v46.2 FIX
            if (growThreads > 0) {
                const growDelay = Math.max(0, weakenTime - growTime + SPACING);
                
                jobs.push({
                    type: "grow",
                    target: target,
                    threads: growThreads,
                    ramPerThread: growRam,
                    delay: growDelay,
                    priority: 2,
                    endTime: now + growDelay + growTime
                });
            }
            
            // JOB 3: WEAKEN compensatoire (termine 2Г—SPACING aprГЁs WEAKEN1) - v46.2 FIX
            if (compensateWeakenThreads > 0) {
                const weaken2Delay = 2 * SPACING;
                
                jobs.push({
                    type: "weaken",
                    target: target,
                    threads: compensateWeakenThreads,
                    ramPerThread: weakenRam,
                    delay: weaken2Delay,
                    priority: 3,
                    endTime: now + weaken2Delay + weakenTime
                });
            }
            
            // Calcul du ratio pour vГ©rification
            const totalWeaken = weakenThreads + compensateWeakenThreads;
            const ratio = totalWeaken > 0 ?
                `G/W = ${(growThreads / totalWeaken).toFixed(2)}:1` :
                `G only`;
            
            this.log.info(
                `рҹ”Ҙ Prep FULL: W${weakenThreads}t + G${growThreads}t + W${compensateWeakenThreads}t ` +
                `(sec:${prepStatus.securityDelta.toFixed(1)} вҶ’ +${CONFIG.HACKING?.SECURITY_BUFFER || 2}, ` +
                `money:${(currentPercent * 100).toFixed(0)}% вҶ’ ${(targetPercent * 100).toFixed(0)}%, ${ratio})`
            );
            
            return jobs;
        }
        
        // Edge case: Aucune prГ©paration nГ©cessaire (ne devrait jamais arriver ici)
        this.log.warn(`Prep appelГ© mais aucun job crГ©Г© pour ${target}`);
        return [];
    }

    /**
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * рҹҺҜ CALCULATE OPTIMAL HACK PERCENT (EV/s)
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * Calcule le hackPercent optimal en testant plusieurs candidats et en choisissant
     * celui qui maximise l'Expected Value par seconde (EV/s).
     * 
     * @private
     * @param {string} target - Hostname de la cible
     * @returns {number} hackPercent optimal (ex: 0.15 pour 15%)
     */
    _calculateOptimalHackPercent(target) {
        // VГ©rifier si recalcul nГ©cessaire (cache avec TTL)
        const now = Date.now();
        const lastRecalc = this._lastEVRecalc[target] || 0;
        const RECALC_INTERVAL = CONFIG.HACKING?.EV_RECALC_INTERVAL_MS || 120000;
        
        if (this._metrics.optimalHackPercents[target] && 
            (now - lastRecalc) < RECALC_INTERVAL) {
            return this._metrics.optimalHackPercents[target];
        }
        
        // Candidats hackPercent (v46.0 OPTIMISГү : 20 вҶ’ 5)
        const candidates = CONFIG.HACKING?.HACK_PERCENT_CANDIDATES || 
            [0.10, 0.15, 0.20, 0.25, 0.30];
        
        let bestHackPercent = candidates[0];
        let bestEV = 0;
        
        const server = this.ns.getServer(target);
        const weakenTime = this.ns.getWeakenTime(target);
        const SPACING = 200;
        
        // вң… v46.0 BUG #4 CORRIGГү : DurГ©e batch complГЁte
        const batchDuration = weakenTime + (SPACING * 3);
        
        for (const hackPercent of candidates) {
            // Calcul simplifiГ© (sans calculer tous les threads)
            const hackChance = this.ns.hackAnalyzeChance(target);
            const moneyStolen = server.moneyMax * hackPercent * hackChance;
            const expectedValue = moneyStolen;
            
            // вң… EV/s avec durГ©e batch complГЁte
            const evPerSecond = expectedValue / (batchDuration / 1000);
            
            if (evPerSecond > bestEV) {
                bestEV = evPerSecond;
                bestHackPercent = hackPercent;
            }
        }
        
        // Mise Г  jour cache
        this._metrics.optimalHackPercents[target] = bestHackPercent;
        this._lastEVRecalc[target] = now;
        
        return bestHackPercent;
    }

    /**
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * рҹ§® CALCULATE BATCH JOBS (HWGW)
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * Calcule les 4 jobs d'un batch HWGW (Hack, Weaken, Grow, Weaken) avec
     * formules mathГ©matiques exactes et timing prГ©cis.
     * 
     * @private
     * @param {string} target - Hostname de la cible
     * @param {number} hackPercent - Pourcentage d'argent Г  voler (ex: 0.15)
     * @returns {Array<Object>} Liste de 4 jobs HWGW
     */
    _calculateBatchJobs(target, hackPercent) {
        const { hackRam, weakenRam, growRam } = this._getWorkerRamCosts();
        
        let hackThreads, weakenForHackThreads, growThreads, weakenForGrowThreads;
        
        // в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
        // вң… v47.0 BUG #10 CORRIGГү : FORMULE HACKTHREADS AVEC FORMULAS
        // в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
        if (this.caps.formulas) {
            try {
                const server = this.ns.getServer(target);
                const player = this.ns.getPlayer();
                
                // вң… FORMULE CORRECTE (ГүTAIT INVERSГүE)
                const hackPercentPerThread = this.ns.formulas.hacking.hackPercent(server, player);
                hackThreads = Math.floor(hackPercent / hackPercentPerThread);
                
                // Weaken pour compenser hack
                weakenForHackThreads = Math.ceil((hackThreads * 0.002) / 0.05);
                
                // Grow threads (formule prГ©cise)
                const moneyBefore = server.moneyMax;
                const moneyAfter = server.moneyMax * (1 - hackPercent);
                const moneyTarget = server.moneyMax;
                
                server.moneyAvailable = moneyAfter;  // Simuler aprГЁs hack
                
                growThreads = this.ns.formulas.hacking.growThreads(
                    server,
                    player,
                    moneyTarget,
                    1  // cores
                );
                
                server.moneyAvailable = moneyBefore;  // Restaurer
                
                // Weaken pour compenser grow
                weakenForGrowThreads = Math.ceil((growThreads * 0.004) / 0.05);
                
            } catch (error) {
                this.log.warn(`Formulas error: ${error.message}, using approximations`);
                
                // Fallback aux approximations
                const hackAnalyze = this.ns.hackAnalyze(target);
                hackThreads = Math.max(1, Math.floor(hackPercent / hackAnalyze));
                
                const growthNeeded = 1 / (1 - hackPercent);
                growThreads = Math.ceil(this.ns.growthAnalyze(target, growthNeeded));
                
                weakenForHackThreads = Math.ceil((hackThreads * 0.002) / 0.05);
                weakenForGrowThreads = Math.ceil((growThreads * 0.004) / 0.05);
            }
        } else {
            // Sans formulas (approximations)
            const hackAnalyze = this.ns.hackAnalyze(target);
            hackThreads = Math.max(1, Math.floor(hackPercent / hackAnalyze));
            
            const growthNeeded = 1 / (1 - hackPercent);
            growThreads = Math.ceil(this.ns.growthAnalyze(target, growthNeeded));
            
            weakenForHackThreads = Math.ceil((hackThreads * 0.002) / 0.05);
            weakenForGrowThreads = Math.ceil((growThreads * 0.004) / 0.05);
        }
        
        // вң… Toujours au moins 1 thread
        hackThreads = Math.max(1, hackThreads);
        weakenForHackThreads = Math.max(1, weakenForHackThreads);
        growThreads = Math.max(1, growThreads);
        weakenForGrowThreads = Math.max(1, weakenForGrowThreads);
        
        // вң… Limiter grow threads (sГ©curitГ©)
        const MAX_GROW_THREADS = CONFIG.HACKING?.MAX_GROW_THREADS || 10000;
        growThreads = Math.min(growThreads, MAX_GROW_THREADS);
        
        // в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
        // вң… v46.0 BUG #3 CORRIGГү : TIMING HWGW
        // в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
        // Capturer Date.now() UNE FOIS au dГ©but
        const now = Date.now();
        
        const hackTime = this.ns.getHackTime(target);
        const growTime = this.ns.getGrowTime(target);
        const weakenTime = this.ns.getWeakenTime(target);
        
        const SPACING = 200;
        const landTime = now + weakenTime + 1000;
        
        return [
            // JOB 1: HACK (termine Г  landTime)
            {
                type: "hack",
                target: target,
                threads: hackThreads,
                ramPerThread: hackRam,
                delay: Math.max(0, landTime - hackTime - now),
                priority: 1,
                endTime: landTime
            },
            // JOB 2: WEAKEN1 (termine 200ms aprГЁs hack)
            {
                type: "weaken",
                target: target,
                threads: weakenForHackThreads,
                ramPerThread: weakenRam,
                delay: Math.max(0, landTime + SPACING - weakenTime - now),
                priority: 2,
                endTime: landTime + SPACING
            },
            // JOB 3: GROW (termine 400ms aprГЁs hack)
            {
                type: "grow",
                target: target,
                threads: growThreads,
                ramPerThread: growRam,
                delay: Math.max(0, landTime + (SPACING * 2) - growTime - now),
                priority: 3,
                endTime: landTime + (SPACING * 2)
            },
            // JOB 4: WEAKEN2 (termine 600ms aprГЁs hack)
            {
                type: "weaken",
                target: target,
                threads: weakenForGrowThreads,
                ramPerThread: weakenRam,
                delay: Math.max(0, landTime + (SPACING * 3) - weakenTime - now),
                priority: 4,
                endTime: landTime + (SPACING * 3)
            }
        ];
    }

    /**
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * рҹ“Ұ PACK JOBS (FFD Algorithm avec Job Splitting)
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * Empaquette les jobs sur les serveurs disponibles avec l'algorithme FFD
     * (First Fit Decreasing). Inclut le job splitting pour les gros jobs.
     * 
     * @private
     * @param {Array<Object>} jobs - Liste de jobs Г  empaqueter
     * @returns {Array<Object>} Jobs empaquetГ©s avec host assignГ©
     */
    _packJobs(jobs) {
        // вң… v46.0 BUG #6 CORRIGГү : Assertion stricte au lieu de filter
        jobs.forEach((job, idx) => {
            if (job.threads <= 0) {
                throw new Error(`BUG CRITIQUE: Job ${idx} (${job.type}) a ${job.threads} threads`);
            }
            if (job.ramPerThread <= 0) {
                throw new Error(`BUG CRITIQUE: Job ${idx} (${job.type}) a ${job.ramPerThread} RAM/thread`);
            }
        });
        
        // вң… v47.1 FIX : Obtenir RAM disponible sur tous les serveurs
        const ramPools = this.ramMgr.getRamPools();
        
        // CrГ©er une copie mutable pour le packing
        const hostRAMMutable = {};
        for (const server of ramPools.servers) {
            hostRAMMutable[server.hostname] = server.freeRam;
        }
        
        // Trier jobs par RAM dГ©croissante (FFD algorithm)
        const sortedJobs = [...jobs].sort((a, b) => {
            const ramA = a.threads * a.ramPerThread;
            const ramB = b.threads * b.ramPerThread;
            return ramB - ramA;  // DГ©croissant
        });
        
        const packedJobs = [];
        
        for (const job of sortedJobs) {
            const jobRAM = job.threads * job.ramPerThread;
            let remainingThreads = job.threads;
            
            // вң… v46.0 OPT #6 : Job Splitting
            // Si job trop gros pour un seul serveur, dГ©couper en sub-jobs
            while (remainingThreads > 0) {
                // Trouver serveur avec le plus de RAM disponible
                let bestHost = null;
                let maxRAM = 0;
                
                for (const [hostname, ram] of Object.entries(hostRAMMutable)) {
                    if (ram > maxRAM) {
                        maxRAM = ram;
                        bestHost = hostname;
                    }
                }
                
                if (!bestHost || maxRAM < job.ramPerThread) {
                    // Plus assez de RAM nulle part
                    this.log.warn(`Impossible de placer ${remainingThreads} threads ${job.type} (RAM insuffisante)`);
                    this._metrics.totalRamWaste += remainingThreads * job.ramPerThread;
                    break;
                }
                
                // Calculer combien de threads on peut placer
                const threadsToPlace = Math.min(
                    remainingThreads,
                    Math.floor(maxRAM / job.ramPerThread)
                );
                
                if (threadsToPlace === 0) {
                    // MГӘme pas 1 thread (ne devrait jamais arriver avec la vГ©rif ci-dessus)
                    break;
                }
                
                // CrГ©er sub-job
                packedJobs.push({
                    ...job,
                    threads: threadsToPlace,
                    host: bestHost,
                    uuid: `${job.type}-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`
                });
                
                // Mettre Г  jour RAM disponible
                hostRAMMutable[bestHost] -= threadsToPlace * job.ramPerThread;
                remainingThreads -= threadsToPlace;
                
                // MГ©triques job splitting
                if (remainingThreads > 0) {
                    this._metrics.jobsSplit++;
                    this._metrics.totalSubjobs++;
                }
            }
        }
        
        return packedJobs;
    }

    /**
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * рҹҡҖ DISPATCH JOBS
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * Envoie les jobs au controller via le port handler avec throttling.
     * 
     * @private
     * @param {Array<Object>} jobs - Jobs empaquetГ©s avec host assignГ©
     * @returns {Promise<number>} Nombre de threads dispatchГ©s
     */
    async _dispatchJobs(jobs) {
        let dispatched = 0;
        
        // вң… v46.0 OPT #5 : Batch delay configurable
        const DISPATCH_DELAY_MS = CONFIG.BATCHER?.DISPATCH_DELAY_MS || 10;
        const BATCH_DELAY_MS = CONFIG.BATCHER?.BATCH_DELAY_MS || 100;
        
        // Port pour envoyer les commandes (depuis CONFIG)
        const COMMANDS_PORT = CONFIG.PORTS?.COMMANDS || 1;
        
        for (const job of jobs) {
            try {
                // вң… v47.2 FIX : Utiliser writeJSONWithRetry au lieu de writeCommand
                const success = await this.portHandler.writeJSONWithRetry(
                    COMMANDS_PORT,
                    {
                        type: job.type,
                        target: job.target,
                        threads: job.threads,
                        delay: job.delay,
                        host: job.host,
                        uuid: job.uuid
                    }
                );
                
                if (success) {
                    dispatched += job.threads;
                } else {
                    this.log.warn(`Dispatch Г©chouГ© pour ${job.type} (${job.threads}t)`);
                }
                
                // Throttling pour Г©viter saturation port
                await this.ns.sleep(DISPATCH_DELAY_MS);
                
            } catch (error) {
                this.log.error(`Erreur dispatch job ${job.type}: ${error.message}`);
            }
        }
        
        this._metrics.batchesDispatched++;
        
        // DГ©lai entre batches pour logs groupГ©s
        await this.ns.sleep(BATCH_DELAY_MS);
        
        return dispatched;
    }

    /**
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * рҹ’ҫ GET WORKER RAM COSTS (avec cache TTL)
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * Retourne le coГ»t RAM de chaque type de worker.
     * 
     * @private
     * @returns {Object} { hackRam, growRam, weakenRam, shareRam }
     */
    _getWorkerRamCosts() {
        // вң… v46.0 BUG #7 CORRIGГү : Cache avec TTL 5min
        const CACHE_TTL_MS = 5 * 60 * 1000;
        
        if (this._workerRamCache !== null && 
            Date.now() - this._workerRamCacheTime < CACHE_TTL_MS) {
            return this._workerRamCache;
        }
        
        // Recalculer
        const hackRam = this.ns.getScriptRam("/hack/workers/hack.js", "home");
        const growRam = this.ns.getScriptRam("/hack/workers/grow.js", "home");
        const weakenRam = this.ns.getScriptRam("/hack/workers/weaken.js", "home");
        const shareRam = this.ns.getScriptRam("/hack/workers/share.js", "home");
        
        this._workerRamCache = { hackRam, growRam, weakenRam, shareRam };
        this._workerRamCacheTime = Date.now();
        
        return this._workerRamCache;
    }

    /**
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * рҹ“Ҡ GET METRICS
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     */
    getMetrics() {
        return {
            ...this._metrics,
            efficiency: this._metrics.totalThreadsPlanned > 0 ?
                (this._metrics.totalThreadsDispatched / this._metrics.totalThreadsPlanned) 
                : 0
        };
    }

    /**
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * рҹ–ЁпёҸ  PRINT METRICS
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     */
    printMetrics(useTPrint = false) {
        const print = useTPrint ? this.ns.tprint.bind(this.ns) : this.ns.print.bind(this.ns);
        const metrics = this.getMetrics();
        
        print("в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ");
        print("рҹ”Ҙ MГүTRIQUES BATCHER - PROMETHEUS v47.2 PORT FIX");
        print("в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ");
        print(`рҹ“Ҡ Batchs crГ©Г©s: ${metrics.batchesCreated}`);
        print(`  - PrГ©paration: ${metrics.prepBatchesCreated || 0}`);
        print(`  - Гүtapes progressives: ${metrics.progressiveSteps || 0}`);
        print(`вң… Batchs dispatchГ©s: ${metrics.batchesDispatched}`);
        print(`вҡҷпёҸ  Threads planifiГ©s: ${metrics.totalThreadsPlanned}`);
        print(`рҹҡҖ Threads dispatchГ©s: ${metrics.totalThreadsDispatched}`);
        print(`рҹ“Ҳ EfficacitГ©: ${(metrics.efficiency * 100).toFixed(1)}%`);
        print(`рҹ’ҫ RAM waste: ${this.ns.formatRam(metrics.totalRamWaste)}`);
        print(`вңӮпёҸ  Jobs dГ©coupГ©s: ${metrics.jobsSplit}`);
        print(`рҹ“Ұ Sous-jobs crГ©Г©s: ${metrics.totalSubjobs}`);
        print(`вқҢ Erreurs critiques: ${metrics.criticalErrors}`);
        print("в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ");
    }
}

/**
 * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
 * рҹ”Ҙ PROMETHEUS SIGNATURE v47.0
 * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
 */
/** @param {NS} ns */
export async function main(ns) {
    ns.tprint("\x1b[38;5;196m");
    ns.tprint("    в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—");
    ns.tprint("    в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қв–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ");
    ns.tprint("    в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в–Ҳв–Ҳв–Ҳв–Ҳв•”в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—     в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—");
    ns.tprint("    в–Ҳв–Ҳв•”в•җв•җв•җв•қ в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•қ     в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘");
    ns.tprint("    в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘ в•ҡв•җв•қ в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘");
    ns.tprint("    в•ҡв•җв•қ     в•ҡв•җв•қ  в•ҡв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ     в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қ   в•ҡв•җв•қ   в•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•җв•қ");
    ns.tprint("                              v47.2 - \"PORT HANDLER FIX\"");
    ns.tprint("\x1b[0m");
    ns.tprint("");
    
    ns.tprint("рҹ”Ҙ BATCHER PROMETHEUS v47.2 - PORT HANDLER FIX");
