/**
 * в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—
 * в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қв–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ
 * в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в–Ҳв–Ҳв–Ҳв–Ҳв•”в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—     в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—
 * в–Ҳв–Ҳв•”в•җв•җв•җв•қ в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•қ     в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘
 * в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘ в•ҡв•җв•қ в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘
 * в•ҡв•җв•қ     в•ҡв•җв•қ  в•ҡв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ     в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қ   в•ҡв•җв•қ   в•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•җв•қ
 *                            v45.3 - "PREP LOGIC INTEGRATED"
 * 
 * @module      core/batcher
 * @description LE CЕ’UR DE PROMETHEUS - Calcule et dispatch les batchs HWGW optimaux.
 *              ImplГ©mente EV/s dynamic hackPercent, FFD packing avec JOB SPLITTING.
 * @author      Claude (Anthropic) + tylersense-ui
 * @version     45.3 - PROMETHEUS PREP LOGIC INTEGRATED
 * @date        2026-03-02
 * @license     MIT
 * @requires    BitBurner v2.8.1+ (Steam)
 * 
 * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
 * рҹ”Ҙ PROMETHEUS v45.3 - INTELLIGENT TARGET PREPARATION
 * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
 * вң“ NOUVEAU : _checkPrepStatus() - VГ©rifie si serveur prГӘt pour HWGW
 * вң“ NOUVEAU : _createPrepBatch() - CrГ©e batchs de prГ©paration automatiques
 * вң“ MODIFIГү : executeBatch() - GГЁre prГ©paration ET exploitation
 * вң“ RГүSULTAT : Serveurs automatiquement optimisГ©s avant hacking
 * 
 * CHANGEMENTS v45.2 вҶ’ v45.3 :
 *   AVANT : Serveurs jamais optimisГ©s (security haute, money bas)
 *   вҶ’ QUE DES HACKS, revenus sous-optimaux
 *   
 *   APRГҲS : PrГ©paration active et intelligente
 *   вҶ’ DГ©tecte security/money insuffisants
 *   вҶ’ CrГ©e batch weaken+grow+compensate
 *   вҶ’ Puis HWGW optimal une fois prГӘt
 * 
 * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
 * рҹ”Ҙ PROMETHEUS v45.2 - CRITICAL BUGFIX
 * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
 * вң“ BUGFIX : hostRAM n'est plus mutГ© entre les jobs
 * вң“ BUGFIX : Chaque job reГ§oit une copie fraГ®che de l'Г©tat RAM
 * вң“ RГүSULTAT : 100% des threads placГ©s au lieu de 0%
 * 
 * BUG CORRIGГү v45.1 вҶ’ v45.2 :
 *   AVANT : _splitJob() modifiait hostRAM en place
 *   вҶ’ Premier job utilisait toute la RAM
 *   вҶ’ Jobs suivants ne trouvaient plus de RAM libre
 *   вҶ’ RГүSULTAT : 0% des threads placГ©s
 *   
 *   APRГҲS : Tracker sГ©parГ© des RAM utilisГ©es
 *   вҶ’ Chaque job voit la RAM disponible correcte
 *   вҶ’ RГүSULTAT : 100% des threads placГ©s
 * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
 * 
 * @usage
 *   import { Batcher } from "/core/batcher.js";
 *   const batcher = new Batcher(ns, network, ramMgr, portHandler, caps);
 *   await batcher.executeBatch("joesguns");
 */

import { CONFIG } from "/lib/constants.js";
import { Logger } from "/lib/logger.js";

/**
 * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
 * рҹ“ҳ CLASSE BATCHER - LE CЕ’UR DE PROMETHEUS (v45.3 PREP LOGIC)
 * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
 * Calcule, optimise et dispatch les batchs HWGW avec algorithmes avancГ©s.
 * VERSION v45.3 avec systГЁme de prГ©paration intelligente intГ©grГ©.
 */
export class Batcher {
    /**
     * Constructeur du Batcher
     * 
     * @param {NS} ns - Namespace BitBurner
     * @param {Network} network - Instance du Network scanner
     * @param {RamManager} ramMgr - Instance du RAM Manager
     * @param {PortHandler} portHandler - Instance du Port Handler
     * @param {Capabilities} caps - Instance des Capabilities
     */
    constructor(ns, network, ramMgr, portHandler, caps) {
        this.ns = ns;
        this.network = network;
        this.ramMgr = ramMgr;
        this.portHandler = portHandler;
        this.caps = caps;
        this.log = new Logger(ns, "BATCHER");
        
        /**
         * MГ©triques du batcher
         * @private
         */
        this._metrics = {
            batchesCreated: 0,
            batchesDispatched: 0,
            totalThreadsPlanned: 0,
            totalThreadsDispatched: 0,
            totalRamWaste: 0,
            lastBatchTime: 0,
            optimalHackPercents: {}, // Cache des hackPercent optimaux par target
            jobsSplit: 0,             // NOUVEAU : Nombre de jobs dГ©coupГ©s
            totalSubjobs: 0,           // NOUVEAU : Nombre total de sous-jobs crГ©Г©s
            prepBatchesCreated: 0     // NOUVEAU v45.3
        };
        
        /** @type {boolean} Mode debug (depuis CONFIG) */
        this._debugMode = CONFIG.SYSTEM.DEBUG_MODE || false;
        
        /** @type {number} Dernier recalcul EV/s par target */
        this._lastEVRecalc = {};
        
        /**
         * Cache RAM des workers (Г©vite appels rГ©pГ©tГ©s Г  getScriptRam)
         * @private
         */
        this._workerRamCache = null;
    }

    /**
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * рҹҺҜ MГүTHODE PRINCIPALE : EXECUTE BATCH
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * Calcule et exГ©cute un batch HWGW complet sur une cible.
     * 
     * @public
     * @param {string} target - Hostname de la cible
     * @returns {Promise<Object>} RГ©sultats du batch { success, jobs, threadsUsed }
     */
    
       async executeBatch(target) {
        try {
            // 1. VГ©rifier si le serveur nГ©cessite prГ©paration (v45.3)
            const server = this.ns.getServer(target);
            const prepStatus = this._checkPrepStatus(server);

            if (!prepStatus.ready) {
                const prepJobs = this._createPrepBatch(target, prepStatus);
                
                if (!prepJobs || prepJobs.length === 0) {
                    return { success: false, jobs: [], threadsUsed: 0 };
                }
                
                const packedJobs = this._packJobs(prepJobs);
                const dispatched = await this._dispatchJobs(packedJobs);
                
                this._metrics.batchesCreated++;
                this._metrics.prepBatchesCreated++;
                
                return { success: dispatched > 0, jobs: packedJobs, threadsUsed: dispatched };
            }

            // Serveur prГӘt вҶ’ Continuer avec batch HWGW normal
            
            // 2. Calculer le hackPercent optimal (EV/s)
            const hackPercent = this._calculateOptimalHackPercent(target);
            
            if (this._debugMode) {
                this.log.debug(`рҹ”Ҙ hackPercent optimal pour ${target}: ${(hackPercent * 100).toFixed(1)}%`);
            }
            
            // 3. Calculer les jobs HWGW
            const jobs = this._calculateBatchJobs(target, hackPercent);
            
            if (!jobs || jobs.length === 0) {
                this.log.warn(`вҡ пёҸ  Aucun job calculГ© pour ${target}`);
                return { success: false, jobs: [], threadsUsed: 0 };
            }
            
            // 4. Packer les jobs (FFD algorithm avec split)
            const packedJobs = this._packJobs(jobs);
            
            if (packedJobs.length === 0) {
                this.log.warn(`вҡ пёҸ  Packing Г©chouГ© - RAM insuffisante`);
                return { success: false, jobs: [], threadsUsed: 0 };
            }
            
            // 5. Dispatcher les jobs
            const dispatched = await this._dispatchJobs(packedJobs);
            
            // 6. MГ©triques
            this._metrics.batchesCreated++;
            if (dispatched > 0) {
                this._metrics.batchesDispatched++;
            }
            
            this._metrics.totalThreadsPlanned += jobs.reduce((sum, j) => sum + j.threads, 0);
            this._metrics.totalThreadsDispatched += dispatched;
            
            if (this._debugMode) {
                this.log.debug(`рҹ“Ҡ Batch ${target}: ${dispatched}/${jobs.reduce((s, j) => s + j.threads, 0)} threads dispatchГ©s`);
            }
            
            return {
                success: dispatched > 0,
                jobs: packedJobs,
                threadsUsed: dispatched
            };
            
        } catch (error) {
            this.log.error(`Erreur dans executeBatch(${target}): ${error.message}`);
            return { success: false, jobs: [], threadsUsed: 0 };
        }
    }

    /**
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * рҹ”Ҙ EV/s OPTIMIZATION - PROMETHEUS CORE
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * Calcule le hackPercent optimal en maximisant Expected Value per Second (EV/s).
     * 
     * @private
     * @param {string} target - Hostname de la cible
     * @returns {number} hackPercent optimal (entre 0.01 et 0.50)
     */
    _calculateOptimalHackPercent(target) {
        const now = Date.now();
        
        // Cache: recalculer seulement toutes les 5 minutes
        if (this._lastEVRecalc[target] && 
            (now - this._lastEVRecalc[target]) < CONFIG.HACKING.EV_RECALC_INTERVAL_MS) {
            return this._metrics.optimalHackPercents[target] || CONFIG.HACKING.HACK_PERCENT;
        }
        
        this._lastEVRecalc[target] = now;
        
        const server = this.ns.getServer(target);
        const player = this.ns.getPlayer();
        
        // Candidats Г  tester
        const candidates = CONFIG.HACKING.HACK_PERCENT_CANDIDATES;
        let bestPercent = CONFIG.HACKING.HACK_PERCENT;
        let bestEVPerSec = -Infinity;
        
        for (const percent of candidates) {
            // Calculer EV/s pour ce candidat
            const evs = this._calculateEVPerSecond(target, percent, server, player);
            
            if (evs > bestEVPerSec) {
                bestEVPerSec = evs;
                bestPercent = percent;
            }
            
            if (this._debugMode) {
                this.log.debug(`  ${(percent * 100).toFixed(1)}%: ${this.ns.formatNumber(evs)}/s`);
            }
        }
        
        // Cacher le rГ©sultat
        this._metrics.optimalHackPercents[target] = bestPercent;
        
        this.log.success(`вң… Optimal hackPercent pour ${target}: ${(bestPercent * 100).toFixed(1)}% (EV/s: ${this.ns.formatNumber(bestEVPerSec)})`);
        
        return bestPercent;
    }

    /**
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * рҹҶ• v45.3 : VГүRIFIER STATUT DE PRГүPARATION
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     */
    _checkPrepStatus(server) {
        const securityMargin = 5;
        const moneyThreshold = 0.75;
        
        const securityDelta = server.hackDifficulty - server.minDifficulty;
        const moneyPercent = server.moneyAvailable / server.moneyMax;
        
        const securityOK = securityDelta <= securityMargin;
        const moneyOK = moneyPercent >= moneyThreshold;
        
        if (securityOK && moneyOK) {
            return {
                ready: true,
                needsWeaken: false,
                needsGrow: false
            };
        }
        
        return {
            ready: false,
            needsWeaken: !securityOK,
            needsGrow: !moneyOK,
            securityDelta: securityDelta,
            moneyPercent: moneyPercent
        };
    }

    /**
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * рҹҶ• v45.3 : CRГүER BATCH DE PRГүPARATION
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     */
    _createPrepBatch(target, prepStatus) {
        const server = this.ns.getServer(target);
        const { weakenRam, growRam } = this._getWorkerRamCosts();
        const jobs = [];
        
        if (prepStatus.needsWeaken) {
            const securityToReduce = prepStatus.securityDelta;
            let weakenThreads = Math.ceil(securityToReduce / 0.05);
            weakenThreads = Math.min(weakenThreads, 5000);
            
            if (weakenThreads > 0) {
                jobs.push({
                    type: 'weaken',
                    target: target,
                    threads: weakenThreads,
                    delay: 0,
                    ramPerThread: weakenRam
                });
            }
        }
        
        if (prepStatus.needsGrow) {
            const currentMoney = Math.max(1, server.moneyAvailable);
            const targetMoney = server.moneyMax;
            const growMultiplier = targetMoney / currentMoney;
            
            let growThreads = Math.ceil(this.ns.growthAnalyze(target, growMultiplier));
            growThreads = Math.min(growThreads, 5000);
            
            if (growThreads > 0) {
                jobs.push({
                    type: 'grow',
                    target: target,
                    threads: growThreads,
                    delay: 0,
                    ramPerThread: growRam
                });
                
                const compensateWeakenThreads = Math.ceil((growThreads * 0.004) / 0.05);
                jobs.push({
                    type: 'weaken',
                    target: target,
                    threads: compensateWeakenThreads,
                    delay: 0,
                    ramPerThread: weakenRam
                });
            }
        }
        
        return jobs;
    }

    /**
     * Calcule l'Expected Value per Second pour un hackPercent donnГ©
     * 
     * Formule: EV/s = (chance Г— moneyStolen - costWeakenGrow) / duration
     * 
     * @private
     * @param {string} target - Hostname
     * @param {number} hackPercent - Pourcentage Г  hack (0.0 - 1.0)
     * @param {Server} server - Objet serveur
     * @param {Player} player - Objet joueur
     * @returns {number} EV/s (peut ГӘtre nГ©gatif si coГ»t > gain)
     */
    _calculateEVPerSecond(target, hackPercent, server, player) {
        // Calculer avec Formulas si disponible (prГ©cis)
        if (this.caps.formulas) {
            try {
                const chance = this.ns.formulas.hacking.hackChance(server, player);
                const moneyStolen = this.ns.formulas.hacking.hackPercent(server, player) * server.moneyMax * hackPercent;
                const duration = this.ns.formulas.hacking.weakenTime(server, player);
                
                // CoГ»t approximatif des opГ©rations weaken/grow
                // (simplifiГ©: on ne calcule pas exactement les threads ici)
                const cost = 0; // ГҖ affiner si besoin
                
                const ev = (chance * moneyStolen) - cost;
                const evPerSec = ev / (duration / 1000);
                
                return evPerSec;
            } catch (e) {
                // Fallback si formulas Г©choue
            }
        }
        
        // Approximation sans Formulas
        const chance = this.ns.hackAnalyzeChance(target);
        const moneyStolen = server.moneyMax * hackPercent;
        const duration = this.ns.getWeakenTime(target);
        
        const ev = (chance * moneyStolen);
        const evPerSec = ev / (duration / 1000);
        
        return evPerSec;
    }

    /**
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * рҹ’ҫ RГүCUPГүRATION DYNAMIQUE DE LA RAM DES WORKERS
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * Utilise ns.getScriptRam() pour obtenir les valeurs exactes (FIX CRITIQUE).
     * Cache les rГ©sultats pour Г©viter les appels rГ©pГ©tГ©s.
     * 
     * @private
     * @returns {Object} { hackRam, growRam, weakenRam, shareRam }
     */
    _getWorkerRamCosts() {
        // Utiliser le cache si dГ©jГ  calculГ©
        if (this._workerRamCache) {
            return this._workerRamCache;
        }

        // Calculer les RAM exactes via ns.getScriptRam()
        try {
            const hackRam = this.ns.getScriptRam('/hack/workers/hack.js');
            const growRam = this.ns.getScriptRam('/hack/workers/grow.js');
            const weakenRam = this.ns.getScriptRam('/hack/workers/weaken.js');
            const shareRam = this.ns.getScriptRam('/hack/workers/share.js');

            // VГ©rifier que les valeurs sont valides
            if (hackRam <= 0 || growRam <= 0 || weakenRam <= 0) {
                throw new Error("RAM invalide dГ©tectГ©e pour les workers");
            }

            // Cacher les rГ©sultats
            this._workerRamCache = {
                hackRam: hackRam,
                growRam: growRam,
                weakenRam: weakenRam,
                shareRam: shareRam
            };

            if (this._debugMode) {
                this.log.debug(`рҹ’ҫ RAM workers: H=${hackRam.toFixed(2)}GB G=${growRam.toFixed(2)}GB W=${weakenRam.toFixed(2)}GB`);
            }

            return this._workerRamCache;

        } catch (error) {
            // Fallback sur valeurs approximatives si getScriptRam Г©choue
            this.log.warn(`вҡ пёҸ  Гүchec getScriptRam, fallback sur valeurs approximatives: ${error.message}`);
            
            this._workerRamCache = {
                hackRam: 1.70,
                growRam: 1.75,
                weakenRam: 1.75,
                shareRam: 4.00
            };

            return this._workerRamCache;
        }
    }

    /**
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * рҹ§® CALCUL DES JOBS HWGW
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * Calcule les 4 jobs (Hack, Weaken, Grow, Weaken) avec timing prГ©cis.
     * 
     * @private
     * @param {string} target - Hostname
     * @param {number} hackPercent - Pourcentage optimal Г  hack
     * @returns {Array<Object>} Liste des jobs [{type, target, threads, delay, ramPerThread}]
     */
    _calculateBatchJobs(target, hackPercent) {
        const server = this.ns.getServer(target);
        const player = this.ns.getPlayer();
        
        // в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
        // RAM DYNAMIQUE DES WORKERS (FIX CRITIQUE)
        // в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
        const { hackRam, growRam, weakenRam } = this._getWorkerRamCosts();
        
        // в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
        // TIMING (avec Formulas si disponible)
        // в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
        
        let hackTime, growTime, weakenTime;
        
        if (this.caps.formulas) {
            hackTime = this.ns.formulas.hacking.hackTime(server, player);
            growTime = this.ns.formulas.hacking.growTime(server, player);
            weakenTime = this.ns.formulas.hacking.weakenTime(server, player);
        } else {
            hackTime = this.ns.getHackTime(target);
            growTime = this.ns.getGrowTime(target);
            weakenTime = this.ns.getWeakenTime(target);
        }
        
        const buffer = CONFIG.HACKING.TIMING_BUFFER_MS;
        
        // в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
        // CALCUL DES THREADS
        // в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
        
        // Hack threads
        const hackThreads = Math.max(1, Math.floor(hackPercent / this.ns.hackAnalyze(target)));
        
        // Weaken1 threads (compense hack)
        const weakenThreads1 = Math.max(1, Math.ceil((hackThreads * 0.002) / 0.05));
        
        // Grow threads (ramГЁne Г  100%)
        const growMultiplier = 1 / (1 - hackPercent);
        let growThreads = Math.max(1, Math.ceil(this.ns.growthAnalyze(target, growMultiplier)));
        
        // Limiter grow threads (sГ©curitГ©)
        growThreads = Math.min(growThreads, CONFIG.HACKING.MAX_GROW_THREADS || 10000);
        
        // Weaken2 threads (compense grow)
        const weakenThreads2 = Math.max(1, Math.ceil((growThreads * 0.004) / 0.05));
        
        // в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
        // CALCUL DES DГүLAIS (synchronisation HWGW)
        // в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
        
        // Weaken est le plus long - il part en premier et finit en premier
        const hackDelay = weakenTime - hackTime - buffer;
        const weaken1Delay = 0; // Part en premier
        const growDelay = weakenTime - growTime + buffer;
        const weaken2Delay = buffer * 2; // Finit 200ms aprГЁs weaken1
        
        // в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
        // CONSTRUCTION DES JOBS (avec RAM DYNAMIQUE)
        // в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
        
        const jobs = [
            {
                type: 'hack',
                target: target,
                threads: hackThreads,
                delay: Math.max(0, hackDelay),
                ramPerThread: hackRam  // вң… DYNAMIQUE
            },
            {
                type: 'weaken',
                target: target,
                threads: weakenThreads1,
                delay: Math.max(0, weaken1Delay),
                ramPerThread: weakenRam  // вң… DYNAMIQUE
            },
            {
                type: 'grow',
                target: target,
                threads: growThreads,
                delay: Math.max(0, growDelay),
                ramPerThread: growRam  // вң… DYNAMIQUE
            },
            {
                type: 'weaken',
                target: target,
                threads: weakenThreads2,
                delay: Math.max(0, weaken2Delay),
                ramPerThread: weakenRam  // вң… DYNAMIQUE
            }
        ];
        
        return jobs;
    }

    /**
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * вңӮпёҸ BUGFIX v45.2 : SPLIT JOB - DГүCOUPAGE SANS MUTATION
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * DГ©coupe un job trop gros en plusieurs sous-jobs qui rentrent sur les serveurs.
     * 
     * BUGFIX v45.2 : N'utilise plus hostRAM directement, mais un tracker sГ©parГ©.
     * 
     * @private
     * @param {Object} job - Job Г  dГ©couper {type, target, threads, delay, ramPerThread}
     * @param {Array<Object>} hostRAM - Liste des serveurs [{hostname, freeRam}]
     * @param {Map<string, number>} ramUsed - Tracker des RAM utilisГ©es par hostname
     * @returns {Array<Object>} Liste des sous-jobs avec host assignГ©
     */
    _splitJob(job, hostRAM, ramUsed) {
        const subjobs = [];
        let remainingThreads = job.threads;
        const minThreadsPerSubjob = CONFIG.HACKING.MIN_THREADS_PER_SUBJOB || 1;
        
        if (this._debugMode) {
            this.log.debug(`вңӮпёҸ DГ©coupage job ${job.type} (${job.threads}t)`);
        }
        
        // Parcourir les serveurs par RAM libre dГ©croissante
        for (const host of hostRAM) {
            if (remainingThreads <= 0) break;
            
            // Calculer la RAM vraiment libre (freeRam - dГ©jГ  utilisГ©e)
            const alreadyUsed = ramUsed.get(host.hostname) || 0;
            const actualFreeRam = host.freeRam - alreadyUsed;
            
            if (actualFreeRam <= 0) continue;
            
            // Calculer combien de threads peuvent rentrer
            const maxThreadsOnHost = Math.floor(actualFreeRam / job.ramPerThread);
            
            if (maxThreadsOnHost < minThreadsPerSubjob) {
                continue;
            }
            
            // Placer autant de threads que possible
            const threadsToPlace = Math.min(maxThreadsOnHost, remainingThreads);
            const ramNeeded = threadsToPlace * job.ramPerThread;
            
            // CrГ©er un sous-job
            subjobs.push({
                type: job.type,
                target: job.target,
                threads: threadsToPlace,
                delay: job.delay,
                ramPerThread: job.ramPerThread,
                host: host.hostname
            });
            
            // BUGFIX v45.2 : Mettre Г  jour le tracker sГ©parГ©
            ramUsed.set(host.hostname, alreadyUsed + ramNeeded);
            remainingThreads -= threadsToPlace;
            
            if (this._debugMode) {
                this.log.debug(`  вң… Sous-job (${threadsToPlace}t) вҶ’ ${host.hostname}`);
            }
        }
        
        // VГ©rifier si tous les threads ont Г©tГ© placГ©s
        if (remainingThreads > 0) {
            this.log.warn(`вҡ пёҸ  Job ${job.type}: ${remainingThreads}/${job.threads} threads non placГ©s`);
        }
        
        // MГ©triques
        if (subjobs.length > 1) {
            this._metrics.jobsSplit++;
            this._metrics.totalSubjobs += subjobs.length;
        }
        
        return subjobs;
    }

    /**
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * рҹ“Ұ BUGFIX v45.2 : FFD PACKING AVEC TRACKER RAM
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * First Fit Decreasing - Minimise la fragmentation RAM.
     * BUGFIX v45.2 : Utilise un tracker Map pour Г©viter la mutation de hostRAM.
     * 
     * @private
     * @param {Array<Object>} jobs - Liste des jobs Г  packer
     * @returns {Array<Object>} Jobs packГ©s avec host assignГ©
     */
    _packJobs(jobs) {
        // RГ©cupГ©rer tous les serveurs avec root access
        const allServers = this.network.refresh();
        const availableHosts = allServers.filter(h => this.ns.hasRootAccess(h));
        
        // Sort jobs by RAM needed (descending)
        const sortedJobs = [...jobs].sort((a, b) => {
            const ramA = a.threads * a.ramPerThread;
            const ramB = b.threads * b.ramPerThread;
            return ramB - ramA;
        });
        
        // RГ©cupГ©rer la RAM disponible sur chaque host
        const hostRAM = availableHosts.map(h => ({
            hostname: h,
            freeRam: this.ramMgr.getRamInfo(h).freeRam
        }));
        
        // Sort hosts by free RAM (descending)
        hostRAM.sort((a, b) => b.freeRam - a.freeRam);
        
        // BUGFIX v45.2 : Tracker sГ©parГ© pour les RAM utilisГ©es
        const ramUsed = new Map();
        
        // Pack jobs (FFD avec split)
        const packedJobs = [];
        
        for (const job of sortedJobs) {
            const ramNeeded = job.threads * job.ramPerThread;
            
            // Trouver le premier host avec assez de RAM (First-Fit)
            let placed = false;
            
            for (const host of hostRAM) {
                const alreadyUsed = ramUsed.get(host.hostname) || 0;
                const actualFreeRam = host.freeRam - alreadyUsed;
                
                if (actualFreeRam >= ramNeeded) {
                    // Placer le job entier sur ce host
                    packedJobs.push({
                        ...job,
                        host: host.hostname
                    });
                    
                    // Mettre Г  jour le tracker
                    ramUsed.set(host.hostname, alreadyUsed + ramNeeded);
                    placed = true;
                    
                    if (this._debugMode) {
                        this.log.debug(`рҹ“Ұ Packed ${job.type} (${job.threads}t) sur ${host.hostname}`);
                    }
                    
                    break;
                }
            }
            
            if (!placed) {
                // в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
                // JOB SPLITTING avec tracker ramUsed
                // в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
                
                if (this._debugMode) {
                    this.log.debug(`рҹ”Қ Job ${job.type} (${job.threads}t) trop gros вҶ’ DГ©coupage`);
                }
                
                const subjobs = this._splitJob(job, hostRAM, ramUsed);
                
                if (subjobs.length > 0) {
                    packedJobs.push(...subjobs);
                    
                    if (this._debugMode) {
                        const totalThreadsPlaced = subjobs.reduce((sum, sj) => sum + sj.threads, 0);
                        this.log.debug(`вң… DГ©coupГ© en ${subjobs.length} sous-jobs (${totalThreadsPlaced}/${job.threads}t placГ©s)`);
                    }
                } else {
                    this.log.warn(`вҡ пёҸ  Job ${job.type} (${job.threads}t) skippГ© - RAM insuffisante mГӘme aprГЁs dГ©coupage`);
                    this._metrics.totalRamWaste += ramNeeded;
                }
            }
        }
        
        return packedJobs;
    }

    /**
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * рҹҡҖ DISPATCH DES JOBS
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * Гүcrit les jobs dans le port 4 pour que le controller les exГ©cute.
     * 
     * @private
     * @param {Array<Object>} jobs - Jobs packГ©s avec host
     * @returns {Promise<number>} Nombre de threads dispatchГ©s
     */
    async _dispatchJobs(jobs) {
    let threadsDispatched = 0;
    
    for (const job of jobs) {
        try {
            const success = await this.portHandler.writeJSONWithRetry(
                CONFIG.PORTS.COMMANDS,
                job,
                5,
                50
            );
            
            if (success) {
                threadsDispatched += job.threads;
            } else {
                this.log.warn(`вҡ пёҸ  Гүchec dispatch ${job.type} sur ${job.host}`);
            }
            
            // вң… DГүLAI ANTI-CONTENTION : 10ms entre chaque dispatch
            await this.ns.sleep(10);
            
        } catch (error) {
            this.log.error(`Erreur dispatch: ${error.message}`);
        }
    }
    
    return threadsDispatched;
}


    /**
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     * рҹ“Ҡ MГүTRIQUES ET UTILITAIRES
     * в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
     */

    /**
     * Retourne les mГ©triques du batcher
     * 
     * @public
     * @returns {Object} MГ©triques dГ©taillГ©es
     */
    getMetrics() {
        return {
            ...this._metrics,
            uptime: Date.now() - (this._metrics.startTime || Date.now()),
            efficiency: this._metrics.totalThreadsPlanned > 0 
                ? (this._metrics.totalThreadsDispatched / this._metrics.totalThreadsPlanned) 
                : 0
        };
    }

    /**
     * Affiche un rapport des mГ©triques
     * 
     * @public
     * @param {boolean} [useTPrint=false] - Utiliser tprint au lieu de print
     */
    printMetrics(useTPrint = false) {
        const print = useTPrint ? this.ns.tprint.bind(this.ns) : this.ns.print.bind(this.ns);
        const metrics = this.getMetrics();
        
        print("в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ");
        print("рҹ”Ҙ MГүTRIQUES BATCHER - PROMETHEUS v45.2 BUGFIX");
        print("в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ");
        print(`рҹ“Ҡ Batchs crГ©Г©s: ${metrics.batchesCreated}`);
        print(`вң… Batchs dispatchГ©s: ${metrics.batchesDispatched}`);
        print(`вҡҷпёҸ  Threads planifiГ©s: ${metrics.totalThreadsPlanned}`);
        print(`рҹҡҖ Threads dispatchГ©s: ${metrics.totalThreadsDispatched}`);
        print(`рҹ“Ҳ EfficacitГ©: ${(metrics.efficiency * 100).toFixed(1)}%`);
        print(`рҹ’ҫ RAM waste: ${this.ns.formatRam(metrics.totalRamWaste)}`);
        print(`вңӮпёҸ Jobs dГ©coupГ©s: ${metrics.jobsSplit}`);
        print(`рҹ“Ұ Sous-jobs crГ©Г©s: ${metrics.totalSubjobs}`);
        print(`  - PrГ©paration: ${metrics.prepBatchesCreated || 0}`);
        print("в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ");
    }
}

/**
